{
    "name": "postgresql-column-order-editor",
    "version": "0.0.5",
    "description": "Electron desktop tool for safely reordering PostgreSQL table columns",
    "main": "./out/main/index.js",
    "author": "@emrecpp",
    "repository": {
        "type": "git",
        "url": "https://github.com/emrecpp/postgresql-column-order-editor.git"
    },
    "scripts": {
        "dev": "electron-vite dev --inspect --sourcemap",
        "build": "tsc --noEmit && electron-vite build",
        "dist": "node scripts/run-dist.cjs --publish never",
        "dist:publish": "node scripts/run-dist.cjs --publish always",
        "deploy": "node scripts/run-release-it.cjs patch --ci",
        "deploy:dry": "node scripts/run-release-it.cjs patch --ci --dry-run --git.requireCleanWorkingDir=false"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@fontsource/public-sans": "^5.2.7",
        "@radix-ui/react-checkbox": "^1.3.3",
        "@radix-ui/react-dialog": "^1.1.15",
        "@simplestack/store": "^0.7.7",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "electron-updater": "^6.8.3",
        "lucide-react": "^1.11.0",
        "pg": "^8.20.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "shadcn": "^4.5.0",
        "tailwind-merge": "^3.5.0",
        "tw-animate-css": "^1.4.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/node": "^25.6.0",
        "@types/pg": "^8.20.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.2.0",
        "autoprefixer": "^10.5.0",
        "code-inspector-plugin": "^1.5.1",
        "electron": "^41.3.0",
        "electron-builder": "^26.8.1",
        "electron-vite": "^5.0.0",
        "postcss": "^8.5.12",
        "release-it": "^20.0.1",
        "tailwindcss": "^3.4.17",
        "typescript": "^6.0.3",
        "vite": "^7.3.2"
    }
}
