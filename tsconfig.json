{
    "compilerOptions": {
        "target": "ES2023",
        "lib": [
            "ES2023",
            "DOM",
            "DOM.Iterable"
        ],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "jsx": "react-jsx",
        "strict": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "verbatimModuleSyntax": true,
        "noEmit": true,
        "ignoreDeprecations": "6.0",
        "baseUrl": ".",
        "types": [
            "node",
            "vite/client"
        ],
        "paths": {
            "@/*": [
                "src/renderer/src/*"
            ],
            "@renderer/*": [
                "src/renderer/src/*"
            ],
            "@shared/*": [
                "src/shared/*"
            ]
        }
    },
    "include": [
        "src/**/*",
        "electron.vite.config.ts"
    ]
}